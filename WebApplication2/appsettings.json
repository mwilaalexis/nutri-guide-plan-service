{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Debug"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "PlanDb": "Server=localhost;Database=PlanDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "FoodService": {
    "BaseUrl": "http://localhost:5284"
  },
  "ProfileService": {
    "BaseUrl": "http://localhost:5284"
  },
  "Serilog": {
